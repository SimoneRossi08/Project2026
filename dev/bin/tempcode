void aggiungiPrestitoAListaUtente(Utente *u, Prestito *p) {
    NodoPrestito *nuovo = malloc(sizeof(NodoPrestito));
    if (nuovo == NULL) return;

    nuovo->prestito = p;
    nuovo->next = u->prestiti;
    u->prestiti = nuovo;
}
time_t now = time(NULL);
struct tm data = *localtime(&now);

strftime(dataInizio, 11, "%Y-%m-%d", &data);

data.tm_mday += 30;
mktime(&data);  // normalizza data

strftime(dataScadenza, 11, "%Y-%m-%d", &data);
